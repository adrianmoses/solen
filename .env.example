# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server
# HOST=0.0.0.0
# PORT=8080

# Database
# DATABASE_URL=sqlite://edgeclaw.db?mode=rwc

# Limits
# MAX_TASKS_PER_USER=20

# Token master key for credential envelope encryption (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# TOKEN_MASTER_KEY=
