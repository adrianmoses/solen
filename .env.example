# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server
# HOST=0.0.0.0
# PORT=8080

# Database
# DATABASE_URL=sqlite://edgeclaw.db?mode=rwc

# Limits
# MAX_TASKS_PER_USER=20

# Skill encryption (AES-256-GCM key for per-skill auth credentials)
# SKILL_ENCRYPTION_KEY=your-encryption-key-here
