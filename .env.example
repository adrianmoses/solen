# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model (defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server
# HOST=0.0.0.0
# PORT=8080

# Database (use /data path inside Docker container)
# DATABASE_URL=sqlite:///data/edgeclaw.db?mode=rwc

# Limits
# MAX_TASKS_PER_USER=20

# Token master key for credential envelope encryption (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# TOKEN_MASTER_KEY=

# Default user ID for auto-registered skills
# DEFAULT_USER_ID=default

# Domain for Caddy TLS (set to your domain in production, defaults to localhost)
# DOMAIN=localhost

# Google Workspace MCP (Gmail + Calendar)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# USER_GOOGLE_EMAIL=

# Skill MCP server URLs
# SKILL_GOOGLE_WORKSPACE_URL=http://workspace-mcp:8000
# SKILL_GITHUB_URL=https://api.githubcopilot.com
# SKILL_GITHUB_AUTH_TOKEN=your-github-pat-here

# Brave Search API (for skill-web-search)
# BRAVE_API_KEY=
